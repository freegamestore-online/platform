{
  "name": "@freegamestore/quality",
  "version": "0.1.0",
  "description": "Quality reporter — games post viewport metrics to a parent dashboard via postMessage so /quality can audit fit / scroll / clipping at every reference viewport without driving a headless browser per game.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "homepage": "https://github.com/freegamestore-online/platform#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/freegamestore-online/platform.git",
    "directory": "packages/quality"
  },
  "bugs": {
    "url": "https://github.com/freegamestore-online/platform/issues"
  },
  "keywords": [
    "freegamestore",
    "quality",
    "audit",
    "viewport"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  },
  "sideEffects": false
}
